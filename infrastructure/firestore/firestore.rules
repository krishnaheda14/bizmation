rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // Null-safe profile fetch - returns data map or null if doc missing.
    // Using exists() first avoids a failed get() call that would throw and deny.
    function safeProfile() {
      let ref = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(ref) ? get(ref).data : null;
    }

    function isSuperAdmin() {
      let p = safeProfile();
      return isAuth() && p != null && p.role == 'SUPER_ADMIN';
    }

    function isOwnerOrStaff() {
      let p = safeProfile();
      return isAuth() && p != null && p.role in ['OWNER', 'STAFF'];
    }

    function callerShopName() {
      let p = safeProfile();
      return p != null ? p.shopName : '';
    }

    function callerShopId() {
      let p = safeProfile();
      return p != null && p.shopId != null ? p.shopId : '';
    }

    function callerEmail() {
      let p = safeProfile();
      return p != null ? p.email : '';
    }

    // ── /users/{uid} ─────────────────────────────────────────────────────────
    // Owners/staff can read customers in their own shop.
    // SUPER_ADMIN can read/update any user.
    // Users can read/update their own doc.
    match /users/{uid} {
      allow read: if isAuth() && (
        request.auth.uid == uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff() && (
            resource.data.shopName == callerShopName()
            || resource.data.shopId == callerShopId()
            || resource.data.shopId == request.auth.uid
          )
        )
      );
      // allow create: user MUST be authenticated and writing their OWN document.
      // getIdToken(true) in AuthContext guarantees the token is fresh at this point.
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (
        request.auth.uid == uid
        || isSuperAdmin()
      );
      allow delete: if isSuperAdmin(); // Super admin can delete users
    }

    // ── /shops/{shopId} ──────────────────────────────────────────────────────
    // Shops are a public directory - anyone (including unauthenticated users)
    // needs to read shops to validate shop names during account creation.
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuth() && (
        request.auth.uid == request.resource.data.ownerUid
        || request.auth.uid == shopId
      );
      allow update: if isAuth() && (
        request.auth.uid == resource.data.ownerUid
        || request.auth.uid == shopId
        || isSuperAdmin()
      );
      allow delete: if isSuperAdmin();

      // ── /shops/{shopId}/customers/{customerId} ────────────────────────────
      // SUPER_ADMIN can read all. Owners/staff can read customers in their shop.
      // A customer can read their own sub-doc. Anyone authenticated can create
      // (needed during customer sign-up before the shop owner is involved).
      match /customers/{customerId} {
        allow read: if isAuth() && (
          request.auth.uid == customerId
          || isSuperAdmin()
          || (isOwnerOrStaff() && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == request.auth.uid)
          || (isOwnerOrStaff() && callerShopName() == get(/databases/$(database)/documents/shops/$(shopId)).data.name)
        );
        allow create: if isAuth();
        allow update: if isAuth() && (
          request.auth.uid == customerId
          || isSuperAdmin()
          || (isOwnerOrStaff() && callerShopName() == get(/databases/$(database)/documents/shops/$(shopId)).data.name)
        );
        allow delete: if false;
      }
    }

    // ── /goldOnlineOrders/{id} ───────────────────────────────────────────────
    match /goldOnlineOrders/{id} {
      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid
        || request.resource.data.customerUid == request.auth.uid
      );
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || resource.data.customerUid == request.auth.uid
        || (callerEmail() != '' && resource.data.customerEmail == callerEmail())
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
            || (
              resource.data.userId != null
              && exists(/databases/$(database)/documents/users/$(resource.data.userId))
              && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.shopName == callerShopName()
            )
          )
        )
      );
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || resource.data.customerUid == request.auth.uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
          )
        )
      );
      allow delete: if false;
    }

    // ── /autoPaySubscriptions/{id} ───────────────────────────────────────────
    match /autoPaySubscriptions/{id} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
            || (
              exists(/databases/$(database)/documents/users/$(resource.data.userId))
              && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.shopName == callerShopName()
            )
          )
        )
      );
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isSuperAdmin()
      );
      allow delete: if false;
    }

    // ── /redemptionRequests/{id} ───────────────────────────────────────────
    match /redemptionRequests/{id} {
      allow create: if isAuth()
        && request.resource.data.customerUid == request.auth.uid;

      allow read: if isAuth() && (
        resource.data.customerUid == request.auth.uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
          )
        )
      );

      allow update: if isAuth() && (
        resource.data.customerUid == request.auth.uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
          )
        )
      );

      allow delete: if false;
    }

    // ── /coinPurchaseOrders/{id} ───────────────────────────────────────────
    match /coinPurchaseOrders/{id} {
      allow create: if isAuth()
        && request.resource.data.customerUid == request.auth.uid;

      allow read: if isAuth() && (
        resource.data.customerUid == request.auth.uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
          )
        )
      );

      allow update: if isAuth() && (
        resource.data.customerUid == request.auth.uid
        || isSuperAdmin()
        || (
          isOwnerOrStaff()
          && (
            (resource.data.shopId != null && resource.data.shopId == callerShopId())
            || (resource.data.shopName != null && resource.data.shopName == callerShopName())
          )
        )
      );

      allow delete: if false;
    }

    // ── /razorpayOrders/{id} ─────────────────────────────────────────────────
    match /razorpayOrders/{id} {
      allow create: if isAuth();
      allow read:   if isAuth() && (
        resource.data.userId == request.auth.uid
        || isSuperAdmin()
      );
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── /phoneIndex/{phone} ──────────────────────────────────────────────────
    // Maps E.164 phone numbers → { email, uid } for phone-based sign-in.
    // Public reads are intentional: the key IS the phone number, so only someone
    // who already knows the phone can look up the linked email.
    match /phoneIndex/{phone} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['email', 'uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if isAuth() && request.auth.uid == resource.data.uid;
      allow delete: if false;
    }

    // ── /config/{id} ────────────────────────────────────────────────────────
    match /config/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── Catch-all: deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


