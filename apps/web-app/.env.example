# ─────────────────────────────────────────────────────────────────────────────
# Web App — Environment Variables
# Copy this file to .env and fill in real values.
# All VITE_* variables are bundled into the client — do NOT put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API (Express) ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ── Supabase (client-side) ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project URL  (e.g.  https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon / public key — this is safe to expose in the browser
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Razorpay (Gold Buy / Sell / AutoPay) ─────────────────────────────────────
# Your Razorpay KEY ID (NOT the secret!) — safe to expose in browser
# Found at: Razorpay Dashboard → Settings → API Keys → Key ID
# Use rzp_test_... for testing, rzp_live_... for production
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXX
