# ─────────────────────────────────────────────────────────────────────────────
# Web App — Environment Variables
# Copy this file to .env and fill in real values.
# All VITE_* variables are bundled into the client — do NOT put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API (Express on Railway) ─────────────────────────────────────────
# Required for Phone OTP and generic backend calls
VITE_API_URL=http://localhost:3000

# ── Cloudflare Gold Worker (optional but recommended) ────────────────────────
# Provides continuous gold/silver price updates every 5 minutes via KV cache.
# Deploy the worker first: docs/CLOUDFLARE_GOLD_WORKER.md
# Example: https://gold-rates-worker.YOUR-SUBDOMAIN.workers.dev
VITE_GOLD_WORKER_URL=

# ── Firebase (Auth + Firestore) ───────────────────────────────────────────────
# Found in: Firebase Console → Project Settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Supabase (optional, client-side) ─────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Your project URL  (e.g.  https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# Anon / public key — this is safe to expose in the browser
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Razorpay (Gold Buy / Sell / AutoPay) ─────────────────────────────────────
# Your Razorpay KEY ID (NOT the secret!) — safe to expose in browser
# Found at: Razorpay Dashboard → Settings → API Keys → Key ID
# Use rzp_test_... for testing, rzp_live_... for production
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
