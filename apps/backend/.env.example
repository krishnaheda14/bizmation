# -----------------------------------------------------------------------------
# Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# -----------------------------------------------------------------------------

# -- App ----------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -- PostgreSQL Database -------------------------------------------------------
# Provide any standard PostgreSQL connection string.
# Examples:
#   Railway PostgreSQL : postgresql://postgres:PASSWORD@HOST:5432/railway
#   Neon               : postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Local dev          : postgresql://postgres:postgres@localhost:5432/bizmation
#
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# Connection pool size
DB_POOL_MAX=10

# -- Auth ---------------------------------------------------------------------
JWT_SECRET=<choose-a-random-256-bit-secret>

# -- Twilio (Phone OTP via Twilio Verify) -------------------------------------
# ⚡ OPTION B (simplest — use this first):
#   1. Go to https://console.twilio.com → Account Info
#   2. Copy "Account SID" (starts with AC)
#   3. Copy "Auth Token" (visible after clicking the eye icon)
#   4. Go to Verify → Services → Create a Service → copy SID (starts with VA)
#
TWILIO_ACCOUNT_SID=AC<your-account-sid>
TWILIO_AUTH_TOKEN=<your-auth-token>
TWILIO_VERIFY_SERVICE_SID=VA<your-verify-service-sid>
#
# ⚡ OPTION A (more secure, uses API Keys instead of Auth Token):
#   Set all four values below AND keep TWILIO_ACCOUNT_SID above.
#   Comment out TWILIO_AUTH_TOKEN when using Option A.
#
# TWILIO_API_KEY_SID=SK<your-api-key-sid>        # Twilio Console → API Keys
# TWILIO_API_KEY_SECRET=<your-api-key-secret>     # API Key Secret

# -- Gold Rate Settings --------------------------------------------------------
GOLD_RATE_TTL_SECONDS=300

# -- Optional: AI services -----------------------------------------------------
AI_SERVICES_URL=http://localhost:8000
