# ─────────────────────────────────────────────────────────────────────────────
# Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project URL  (e.g.  https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service Role key — has full DB access, keep server-side ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Anon / public key — safe for browser but not needed on the backend usually
SUPABASE_ANON_KEY=<your-anon-key>

# ── Direct PostgreSQL connection (used by DatabaseService / pg Pool) ──────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
#   • Use "Session mode" pooler (port 5432) for normal queries
#   • Use "Transaction mode" pooler (port 6543) if you have many short-lived connections
#
# Format:
#   postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Connection pool size — keep ≤ 15 on Free tier, ≤ 80 on Pro
DB_POOL_MAX=10

# ── Auth ─────────────────────────────────────────────────────────────────────
# Used for signing JWT tokens if you implement custom auth alongside Supabase Auth
JWT_SECRET=<choose-a-random-256-bit-secret>

# ── Optional: AI services ─────────────────────────────────────────────────────
AI_SERVICES_URL=http://localhost:8000
