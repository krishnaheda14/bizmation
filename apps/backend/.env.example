# -----------------------------------------------------------------------------
# Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# -----------------------------------------------------------------------------

# -- App ----------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -- PostgreSQL Database -------------------------------------------------------
# Provide any standard PostgreSQL connection string.
# Examples:
#   Railway PostgreSQL : postgresql://postgres:PASSWORD@HOST:5432/railway
#   Neon               : postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Local dev          : postgresql://postgres:postgres@localhost:5432/bizmation
#
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# Connection pool size
DB_POOL_MAX=10

# -- Auth ---------------------------------------------------------------------
JWT_SECRET=<choose-a-random-256-bit-secret>

# -- Twilio (Phone OTP via Twilio Verify) -------------------------------------
# Twilio Console ? Account Info ? Account SID (starts with AC)
TWILIO_ACCOUNT_SID=AC<your-account-sid>
# Twilio Console ? API Keys & Tokens ? API Key SID (starts with SK)
TWILIO_API_KEY_SID=SK<your-api-key-sid>
# Twilio Console ? API Keys & Tokens ? API Key Secret
TWILIO_API_KEY_SECRET=<your-api-key-secret>
# Twilio Console ? Verify ? Services ? Create a Service ? copy SID (starts with VA)
TWILIO_VERIFY_SERVICE_SID=VA<your-verify-service-sid>

# -- Gold Rate Settings --------------------------------------------------------
GOLD_RATE_TTL_SECONDS=300

# -- Optional: AI services -----------------------------------------------------
AI_SERVICES_URL=http://localhost:8000
