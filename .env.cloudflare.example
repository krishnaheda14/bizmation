# ==========================================
# CLOUDFLARE PAGES ENVIRONMENT VARIABLES
# Add these in Cloudflare Dashboard > Your Project > Settings > Environment Variables
# ==========================================

# Backend API URL (from Railway deployment)
# REQUIRED for Phone OTP (Twilio) to work
VITE_API_URL=https://your-backend.railway.app

# Cloudflare Gold Worker URL (for continuous real-time gold price fetching)
# Deploy the worker first — see docs/CLOUDFLARE_GOLD_WORKER.md
# Format: https://gold-rates-worker.YOUR-SUBDOMAIN.workers.dev
VITE_GOLD_WORKER_URL=https://gold-rates-worker.YOUR-SUBDOMAIN.workers.dev

# Firebase config (get from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Razorpay Key ID (public — safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXX

# AI Services URL (from Render deployment, optional)
VITE_AI_SERVICE_URL=https://jewelry-ai-services.onrender.com

# Environment
VITE_APP_ENV=production

# WebSocket URL (optional - for real-time features)
VITE_WS_URL=wss://your-backend.railway.app

# ==========================================
# NOTES:
# - Do NOT include quotes around values in Cloudflare Pages
# - Replace URLs after deploying backend and AI services
# - These are PUBLIC variables (exposed to frontend)
# - Never put sensitive data here (API keys, secrets, etc.)
# - For Twilio OTP to work: VITE_API_URL must point to your running backend
# ==========================================
